# N8N Configuration
# Copie este arquivo para .env e preencha com suas credenciais

# URL da sua instância n8n (sem barra no final)
# Exemplos:
# - https://sua-instancia.app.n8n.cloud
# - http://localhost:5678
N8N_URL=https://sua-instancia.app.n8n.cloud

# API Key do n8n
# Para gerar: Settings > API > Create API Key
N8N_API_KEY=n8n_api_xxxxxxxxxxxxxxxxxxxxx
